#!/usr/bin/env node

import { Command } from 'commander';
import { execSync, spawn } from 'node:child_process';
import { join, dirname } from 'node:path';
import { fileURLToPath } from 'node:url';
import { readFileSync, writeFileSync, existsSync, copyFileSync } from 'node:fs';
import { createInterface } from 'node:readline';

const __dirname = dirname(fileURLToPath(import.meta.url));
const projectRoot = join(__dirname, '..');

// --- First-run setup ---
async function ensureSetup() {
  const envPath = join(projectRoot, '.env');
  if (existsSync(envPath)) return; // already configured

  console.log('\nNo .env file found. Running first-time setup...\n');
  await runConfigure();
}

const program = new Command();

program
  .name('sapienx')
  .description('SapienX — Personal AI Assistant')
  .version('1.0.0');

// sapienx start
program
  .command('start')
  .description('Start SapienX daemon (via pm2)')
  .action(async () => {
    await ensureSetup();
    try {
      execSync(`pm2 start ${join(projectRoot, 'ecosystem.config.js')}`, {
        stdio: 'inherit',
        cwd: projectRoot
      });
    } catch {
      console.log('Starting SapienX daemon...');
      const logPath = join(projectRoot, 'data', 'sapienx.log');
      // Clear old log for fresh start
      writeFileSync(logPath, '');
      const fs = await import('node:fs');
      const logFd = fs.openSync(logPath, 'a');
      const child = spawn('node', [join(projectRoot, 'index.js'), '--daemon'], {
        stdio: ['ignore', logFd, logFd],
        cwd: projectRoot,
        detached: true
      });
      child.unref();
      writeFileSync(join(projectRoot, 'data', 'sapienx.pid'), String(child.pid));

      // Wait for WhatsApp to connect (poll log file)
      console.log(`Daemon started (PID: ${child.pid}). Waiting for WhatsApp...`);
      let connected = false;
      for (let i = 0; i < 30; i++) { // 30 seconds max
        await new Promise(r => setTimeout(r, 1000));
        try {
          const log = readFileSync(logPath, 'utf-8');
          if (log.includes('[WhatsApp] Connected and ready.')) {
            connected = true;
            break;
          }
          if (log.includes('[WhatsApp] Scan this QR code')) {
            console.log('WhatsApp needs QR scan. Run: sapienx configure');
            break;
          }
        } catch {}
        if (i % 5 === 4) process.stdout.write('.');
      }
      if (connected) {
        console.log('\nSapienX is running. WhatsApp connected.');
      } else if (!connected) {
        console.log('\nDaemon started but WhatsApp may not be ready yet.');
      }
      console.log(`Logs: sapienx logs`);
      console.log('TUI:  sapienx tui');
      console.log('Stop: sapienx stop');
    }
  });

// sapienx stop
program
  .command('stop')
  .description('Stop SapienX daemon')
  .action(() => {
    // Try pm2 first
    try {
      execSync('pm2 stop sapienx 2>/dev/null', { stdio: 'inherit' });
      return;
    } catch {}

    // Fall back to PID file
    const pidPath = join(projectRoot, 'data', 'sapienx.pid');
    if (existsSync(pidPath)) {
      const pid = readFileSync(pidPath, 'utf-8').trim();
      if (!pid) {
        console.log('No running SapienX daemon found.');
        return;
      }
      try {
        process.kill(parseInt(pid), 'SIGTERM');
        writeFileSync(pidPath, '');
        console.log(`SapienX stopped (PID: ${pid}).`);
      } catch {
        console.log(`Process ${pid} not running.`);
        writeFileSync(pidPath, '');
      }
    } else {
      console.log('No running SapienX daemon found.');
    }
  });

// sapienx restart
program
  .command('restart')
  .description('Restart SapienX daemon')
  .action(() => {
    try {
      execSync('pm2 restart sapienx', { stdio: 'inherit' });
    } catch {
      console.log('pm2 not available. Stop and start manually.');
    }
  });

// sapienx tui
program
  .command('tui')
  .description('Start TUI-only mode')
  .option('--cli <adapter>', 'CLI adapter to use')
  .option('--model <model>', 'Model override')
  .action(async (opts) => {
    await ensureSetup();
    const args = [join(projectRoot, 'index.js'), '--tui-only'];
    if (opts.cli) args.push('--cli', opts.cli);
    if (opts.model) args.push('--model', opts.model);
    const child = spawn('node', args, {
      stdio: 'inherit',
      cwd: projectRoot
    });
    child.on('exit', (code) => process.exit(code));
  });

// sapienx configure
async function runConfigure() {
  const inquirer = (await import('inquirer')).default;

  console.log('\n=== SapienX Configuration ===\n');

  const envPath = join(projectRoot, '.env');

  // Load existing values
  let existing = {};
  if (existsSync(envPath)) {
    const content = readFileSync(envPath, 'utf-8');
    for (const line of content.split('\n')) {
      const match = line.match(/^([A-Z_]+)=(.*)$/);
      if (match) existing[match[1]] = match[2];
    }
  }

  // 1. Owner Settings
  const ownerAnswers = await inquirer.prompt([
    {
      type: 'input',
      name: 'name',
      message: 'Your name:',
      default: existing.OWNER_NAME || ''
    }
  ]);

  // 2. Channels
  const channelAnswer = await inquirer.prompt([
    {
      type: 'checkbox',
      name: 'channels',
      message: 'Which channels do you want to enable?',
      choices: [
        { name: 'WhatsApp', value: 'whatsapp', checked: (existing.CHANNELS || 'whatsapp,tui').includes('whatsapp') },
        { name: 'TUI (Terminal)', value: 'tui', checked: (existing.CHANNELS || 'whatsapp,tui').includes('tui') },
        { name: 'Telegram (coming soon)', value: 'telegram', disabled: 'V2' }
      ]
    }
  ]);

  const channels = channelAnswer.channels;
  let phone = existing.OWNER_PHONE || '';
  let allowedNumbers = existing.ALLOWED_NUMBERS || '';
  let groupPolicy = existing.GROUP_POLICY || 'ignore';
  let allowedGroups = existing.ALLOWED_GROUPS || '';

  // 3. WhatsApp settings (only if WhatsApp selected)
  if (channels.includes('whatsapp')) {
    console.log('\n--- WhatsApp Settings ---\n');

    const waPhoneAnswers = await inquirer.prompt([
      {
        type: 'input',
        name: 'phone',
        message: 'Your WhatsApp phone number (country code, no +):',
        default: (existing.OWNER_PHONE || '').replace(/^\+/, ''),
        validate: (v) => v.match(/^\d{7,15}$/) ? true : 'Enter digits only (7-15 digits)'
      },
      {
        type: 'input',
        name: 'allowedNumbers',
        message: 'Additional allowed numbers (comma-separated, blank for owner only):',
        default: existing.ALLOWED_NUMBERS || '',
        filter: (v) => v.replace(/\+/g, '').replace(/\s/g, '')
      }
    ]);

    // Separate prompt for list type (renders better)
    const groupPolicyAnswer = await inquirer.prompt([
      {
        type: 'list',
        name: 'groupPolicy',
        message: 'How should SapienX handle group messages?',
        choices: [
          { name: 'Ignore all groups (default)', value: 'ignore' },
          { name: 'Only respond in allowed groups', value: 'allowlist' },
          { name: 'Respond in all groups', value: 'all' }
        ],
        default: existing.GROUP_POLICY || 'ignore'
      }
    ]);

    phone = waPhoneAnswers.phone;
    allowedNumbers = waPhoneAnswers.allowedNumbers;
    groupPolicy = groupPolicyAnswer.groupPolicy;

    if (groupPolicy === 'allowlist') {
      // Try to fetch groups from WhatsApp if session exists
      const waAuthPath2 = join(projectRoot, '.wwebjs_auth');
      let fetchedGroups = [];

      if (existsSync(waAuthPath2)) {
        const fetchAnswer = await inquirer.prompt([
          { type: 'confirm', name: 'fetch', message: 'Fetch your WhatsApp groups to select from?', default: true }
        ]);

        if (fetchAnswer.fetch) {
          console.log('  Connecting to WhatsApp to fetch groups...');
          try {
            const pkg = (await import('whatsapp-web.js')).default;
            const { Client: WaClient, LocalAuth: WaLocalAuth } = pkg;
            const tmpClient = new WaClient({
              authStrategy: new WaLocalAuth(),
              puppeteer: { headless: true, args: ['--no-sandbox', '--disable-setuid-sandbox'] }
            });

            fetchedGroups = await new Promise((resolve) => {
              const timeout = setTimeout(() => { tmpClient.destroy().catch(() => {}); resolve([]); }, 30000);

              tmpClient.on('ready', async () => {
                try {
                  const chats = await tmpClient.getChats();
                  const groups = chats.filter(c => c.isGroup).map(c => ({
                    id: c.id._serialized,
                    name: c.name
                  }));
                  clearTimeout(timeout);
                  await tmpClient.destroy();
                  resolve(groups);
                } catch {
                  clearTimeout(timeout);
                  await tmpClient.destroy().catch(() => {});
                  resolve([]);
                }
              });

              tmpClient.initialize().catch(() => { clearTimeout(timeout); resolve([]); });
            });

            if (fetchedGroups.length > 0) {
              console.log(`  Found ${fetchedGroups.length} group(s).`);
            } else {
              console.log('  Could not fetch groups.');
            }
          } catch (err) {
            console.log(`  Error fetching groups: ${err.message}`);
          }
        }
      }

      if (fetchedGroups.length > 0) {
        // Show checkbox list of groups
        const previouslyAllowed = (existing.ALLOWED_GROUPS || '').split(',').filter(Boolean);
        const groupAnswer = await inquirer.prompt([
          {
            type: 'checkbox',
            name: 'allowedGroups',
            message: 'Select groups to respond in:',
            choices: fetchedGroups.map(g => ({
              name: `${g.name} (${g.id})`,
              value: g.id,
              checked: previouslyAllowed.includes(g.id)
            }))
          }
        ]);
        allowedGroups = groupAnswer.allowedGroups.join(',');
      } else {
        // Fallback to manual input
        const groupAnswer = await inquirer.prompt([
          {
            type: 'input',
            name: 'allowedGroups',
            message: 'Allowed group IDs (comma-separated, use "sapienx groups" to find IDs):',
            default: existing.ALLOWED_GROUPS || ''
          }
        ]);
        allowedGroups = groupAnswer.allowedGroups;
      }
    }

    // WhatsApp session management
    const waAuthPath = join(projectRoot, '.wwebjs_auth');
    if (existsSync(waAuthPath)) {
      const waSessionAnswer = await inquirer.prompt([
        {
          type: 'confirm',
          name: 'reset',
          message: 'WhatsApp session exists. Reset and re-scan QR?',
          default: false
        }
      ]);
      if (waSessionAnswer.reset) {
        const { rmSync } = await import('node:fs');
        rmSync(waAuthPath, { recursive: true });
        console.log('  WhatsApp session cleared.');
      }
    } else {
      console.log('  WhatsApp: no session yet. QR code will show on start.');
    }
  }

  // 4. API Keys
  console.log('\n--- API Keys ---\n');
  const apiAnswers = await inquirer.prompt([
    {
      type: 'input',
      name: 'apiKey',
      message: 'Anthropic API key (blank to skip):',
      default: existing.ANTHROPIC_API_KEY || ''
    },
    {
      type: 'input',
      name: 'telegramToken',
      message: 'Telegram bot token (blank to skip):',
      default: existing.TELEGRAM_BOT_TOKEN || ''
    }
  ]);

  // 5. Claude CLI check
  console.log('\n--- Claude CLI ---\n');
  try {
    const ver = execSync('claude --version', { encoding: 'utf-8' }).trim();
    console.log(`  Claude CLI: ${ver}`);
  } catch {
    console.log('  Claude CLI: not installed');
    const installAnswer = await inquirer.prompt([
      { type: 'confirm', name: 'install', message: 'Install Claude CLI now?', default: false }
    ]);
    if (installAnswer.install) {
      execSync('npm install -g @anthropic-ai/claude-code', { stdio: 'inherit' });
    }
  }

  // Write .env
  const envContent = [
    '# SapienX Configuration',
    `OWNER_PHONE=${phone}`,
    `OWNER_NAME=${ownerAnswers.name}`,
    `CHANNELS=${channels.join(',')}`,
    `ALLOWED_NUMBERS=${allowedNumbers}`,
    `GROUP_POLICY=${groupPolicy}`,
    `ALLOWED_GROUPS=${allowedGroups}`,
    `ANTHROPIC_API_KEY=${apiAnswers.apiKey || ''}`,
    `TELEGRAM_BOT_TOKEN=${apiAnswers.telegramToken || ''}`,
    ''
  ].join('\n');
  writeFileSync(envPath, envContent);

  // Ensure data dirs
  const schedulesPath = join(projectRoot, 'data', 'schedules.json');
  const schedulesExample = join(projectRoot, 'data', 'schedules.example.json');
  if (!existsSync(schedulesPath) && existsSync(schedulesExample)) {
    copyFileSync(schedulesExample, schedulesPath);
  }

  console.log('\n=== Configuration saved! ===\n');

  // Stop any running daemon
  const pidPath = join(projectRoot, 'data', 'sapienx.pid');
  if (existsSync(pidPath)) {
    const pid = readFileSync(pidPath, 'utf-8').trim();
    if (pid) {
      try {
        process.kill(parseInt(pid), 'SIGTERM');
        console.log(`Stopped running daemon (PID: ${pid}).`);
        writeFileSync(pidPath, '');
      } catch {}
    }
  }

  // Start SapienX
  const waAuthExists = existsSync(join(projectRoot, '.wwebjs_auth'));
  const needsQr = channels.includes('whatsapp') && !waAuthExists;

  const startAnswer = await inquirer.prompt([
    {
      type: 'list',
      name: 'startMode',
      message: 'Start SapienX now?',
      choices: [
        ...(needsQr ? [
          { name: 'Yes — foreground (needed for QR scan)', value: 'foreground' }
        ] : [
          { name: 'Yes — background daemon', value: 'daemon' }
        ]),
        { name: 'Yes — TUI only', value: 'tui' },
        { name: 'No', value: 'no' }
      ]
    }
  ]);

  if (startAnswer.startMode === 'daemon') {
    console.log('\nStarting SapienX daemon...');
    const logPath = join(projectRoot, 'data', 'sapienx.log');
    writeFileSync(logPath, '');
    const fs = await import('node:fs');
    const logFd = fs.openSync(logPath, 'a');
    const child = spawn('node', [join(projectRoot, 'index.js'), '--daemon'], {
      stdio: ['ignore', logFd, logFd],
      cwd: projectRoot,
      detached: true
    });
    child.unref();
    writeFileSync(join(projectRoot, 'data', 'sapienx.pid'), String(child.pid));

    process.stdout.write('Waiting for WhatsApp');
    let connected = false;
    for (let i = 0; i < 30; i++) {
      await new Promise(r => setTimeout(r, 1000));
      try {
        const log = readFileSync(logPath, 'utf-8');
        if (log.includes('[WhatsApp] Connected and ready.')) { connected = true; break; }
      } catch {}
      if (i % 3 === 2) process.stdout.write('.');
    }
    console.log(connected ? ' connected!' : ' timeout (check: sapienx logs)');
    console.log(`\nSapienX running in background (PID: ${child.pid}).`);
    console.log('Commands: sapienx status | sapienx logs | sapienx stop\n');
  } else if (startAnswer.startMode === 'foreground') {
    console.log('\nStarting SapienX (scan QR when it appears)...\n');
    const child = spawn('node', [join(projectRoot, 'index.js')], {
      stdio: 'inherit', cwd: projectRoot
    });
    child.on('exit', (code) => process.exit(code));
  } else if (startAnswer.startMode === 'tui') {
    console.log('\nStarting TUI...\n');
    const child = spawn('node', [join(projectRoot, 'index.js'), '--tui-only'], {
      stdio: 'inherit', cwd: projectRoot
    });
    child.on('exit', (code) => process.exit(code));
  } else {
    console.log('\nRun: sapienx start | sapienx tui\n');
  }
}

program
  .command('configure')
  .alias('setup')
  .description('Configure SapienX settings (onboarding & reconfiguration)')
  .action(async () => {
    await runConfigure();
  });


// sapienx status
program
  .command('status')
  .description('Show SapienX status')
  .action(() => {
    console.log('=== SapienX Status ===\n');

    // Check daemon
    const pidPath = join(projectRoot, 'data', 'sapienx.pid');
    let daemonRunning = false;
    if (existsSync(pidPath)) {
      const pid = readFileSync(pidPath, 'utf-8').trim();
      if (pid) {
        try {
          process.kill(parseInt(pid), 0); // test if alive
          daemonRunning = true;
          console.log(`  Daemon: RUNNING (PID: ${pid})`);
        } catch {
          console.log('  Daemon: STOPPED');
        }
      } else {
        console.log('  Daemon: STOPPED');
      }
    } else {
      console.log('  Daemon: NOT STARTED');
    }

    // Check .env
    const envPath = join(projectRoot, '.env');
    if (existsSync(envPath)) {
      const env = readFileSync(envPath, 'utf-8');
      const phone = env.match(/^OWNER_PHONE=(.*)$/m)?.[1] || 'not set';
      const name = env.match(/^OWNER_NAME=(.*)$/m)?.[1] || 'not set';
      console.log(`  Owner: ${name} (${phone})`);
    } else {
      console.log('  Config: NOT SET UP (run: sapienx setup)');
    }

    // Check WhatsApp auth
    const waAuthPath = join(projectRoot, '.wwebjs_auth');
    if (existsSync(waAuthPath)) {
      console.log('  WhatsApp: configured (session saved)');
    } else {
      console.log('  WhatsApp: NOT configured (needs QR scan)');
    }

    // Check Claude CLI
    try {
      execSync('claude --version', { stdio: 'ignore' });
      console.log('  Claude CLI: installed');
    } catch {
      console.log('  Claude CLI: NOT INSTALLED');
    }

    // Check logs
    const logPath = join(projectRoot, 'data', 'sapienx.log');
    if (existsSync(logPath)) {
      console.log(`\n  Logs: ${logPath}`);
      console.log('  Last 5 lines:');
      try {
        const lines = readFileSync(logPath, 'utf-8').trim().split('\n').slice(-5);
        lines.forEach(l => console.log(`    ${l}`));
      } catch {}
    }

    console.log('');
  });

// sapienx logs
program
  .command('logs')
  .description('Show daemon logs')
  .option('-f, --follow', 'Follow log output')
  .option('-n, --lines <n>', 'Number of lines to show', '20')
  .action((opts) => {
    const logPath = join(projectRoot, 'data', 'sapienx.log');
    if (!existsSync(logPath)) {
      console.log('No logs yet. Start the daemon first: sapienx start');
      return;
    }
    if (opts.follow) {
      const child = spawn('tail', ['-f', logPath], { stdio: 'inherit' });
      child.on('exit', (code) => process.exit(code));
    } else {
      const lines = readFileSync(logPath, 'utf-8').trim().split('\n');
      lines.slice(-parseInt(opts.lines)).forEach(l => console.log(l));
    }
  });

// sapienx version
program
  .command('version')
  .description('Show version info')
  .action(() => {
    const pkg = JSON.parse(readFileSync(join(projectRoot, 'package.json'), 'utf-8'));
    let gitCommit = 'unknown';
    try {
      gitCommit = execSync('git rev-parse --short HEAD', {
        cwd: projectRoot,
        encoding: 'utf-8'
      }).trim();
    } catch {}
    console.log(`SapienX v${pkg.version} (commit ${gitCommit})`);
    console.log(`Node.js ${process.version}`);
    try {
      const claudeVersion = execSync('claude --version', { encoding: 'utf-8' }).trim();
      console.log(`Claude CLI: ${claudeVersion}`);
    } catch {
      console.log('Claude CLI: not installed');
    }
  });

// sapienx upgrade
program
  .command('upgrade')
  .description('Pull latest code and restart')
  .option('--dry-run', 'Show pending changes only')
  .action((opts) => {
    if (opts.dryRun) {
      execSync('git fetch && git log HEAD..origin/main --oneline', {
        stdio: 'inherit',
        cwd: projectRoot
      });
      return;
    }
    console.log('Pulling latest...');
    execSync('git pull origin main', { stdio: 'inherit', cwd: projectRoot });
    console.log('Installing dependencies...');
    execSync('npm install', { stdio: 'inherit', cwd: projectRoot });
    console.log('Restarting...');
    try {
      execSync('pm2 restart sapienx', { stdio: 'inherit' });
    } catch {
      console.log('pm2 not available. Restart manually: sapienx start');
    }
  });

// sapienx message
program
  .command('message <text>')
  .description('Send a message via a channel')
  .requiredOption('--channel <channel>', 'Channel to send through')
  .requiredOption('--to <recipient>', 'Recipient ID')
  .action(async (text, opts) => {
    // Import and boot just enough to send one message
    const { default: config } = await import(join(projectRoot, 'config', 'sapienx.config.js'));
    const { createBus } = await import(join(projectRoot, 'core', 'bus.js'));
    const bus = createBus();

    if (opts.channel === 'whatsapp') {
      const { WhatsAppChannel } = await import(join(projectRoot, 'channels', 'whatsapp.js'));
      const wa = new WhatsAppChannel(bus, config.channels.whatsapp);

      bus.on('channel:ready', async () => {
        await wa.send({
          to: opts.to,
          text,
          metadata: {}
        });
        console.log(`Message sent to ${opts.to} via WhatsApp.`);
        await wa.stop();
        process.exit(0);
      });

      await wa.start();

      // Timeout after 30s
      setTimeout(() => {
        console.error('Timeout waiting for WhatsApp connection.');
        process.exit(1);
      }, 30000);
    } else {
      console.log(`Channel "${opts.channel}" not supported for direct messaging yet.`);
    }
  });

// sapienx skills
program
  .command('skills')
  .description('List loaded skills')
  .action(async () => {
    const { SkillLoader } = await import(join(projectRoot, 'skills', 'loader.js'));
    const { default: config } = await import(join(projectRoot, 'config', 'sapienx.config.js'));
    const paths = config.skills.paths.map(p =>
      p.startsWith('.') ? join(projectRoot, p) : p
    );
    const loader = new SkillLoader(paths);
    const skills = await loader.loadAll();
    for (const s of skills) {
      console.log(`  ${s.name} [${s.mode}] — ${s.description}`);
      console.log(`    triggers: ${s.triggers.join(', ')}`);
    }
  });

// sapienx health
program
  .command('health')
  .description('Check system health')
  .action(async () => {
    console.log('Checking health...');

    // Claude CLI
    try {
      execSync('claude --version', { stdio: 'ignore' });
      console.log('  Claude CLI: OK');
    } catch {
      console.log('  Claude CLI: NOT FOUND');
    }

    // Node.js
    console.log(`  Node.js: ${process.version}`);

    // pm2
    try {
      const status = execSync('pm2 show sapienx --no-color', { encoding: 'utf-8' });
      const running = status.includes('online');
      console.log(`  Daemon: ${running ? 'RUNNING' : 'STOPPED'}`);
    } catch {
      console.log('  Daemon: pm2 not available');
    }
  });

program.parse();
