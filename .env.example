# SapienX Configuration
# Copy to .env and fill in values: cp .env.example .env

# Owner's WhatsApp phone number (with country code, no +)
OWNER_PHONE=

# Owner display name
OWNER_NAME=

# Additional allowed phone numbers (comma-separated, no +)
# These numbers can also send messages to SapienX
ALLOWED_NUMBERS=

# Group policy: ignore | allowlist | all
# ignore = drop all group messages (default)
# allowlist = only respond in ALLOWED_GROUPS
# all = respond in every group SapienX is in
GROUP_POLICY=ignore

# Allowed group IDs (comma-separated, only used when GROUP_POLICY=allowlist)
# Use "sapienx groups" to find group IDs
ALLOWED_GROUPS=

# Anthropic API key (for Claude CLI)
ANTHROPIC_API_KEY=

# Telegram bot token (future, leave blank for V1)
TELEGRAM_BOT_TOKEN=
