# SapienX Configuration
# Copy to .env and fill in values: cp .env.example .env

# Owner's WhatsApp phone number (with country code, no +)
OWNER_PHONE=

# Owner display name
OWNER_NAME=

# Anthropic API key (for Claude CLI)
ANTHROPIC_API_KEY=

# Telegram bot token (future, leave blank for V1)
TELEGRAM_BOT_TOKEN=
